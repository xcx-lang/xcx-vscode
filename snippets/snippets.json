{
    "--- Variables & Types ---": {
        "prefix": "xvar",
        "body": [
            "${1|i,f,s,b|}: ${2:name} = ${0};"
        ],
        "description": "Variable declaration (pick type)"
    },
    "Const": {
        "prefix": "const",
        "body": [
            "const ${1|i,f,s,b|}: ${2:NAME} = ${0};"
        ],
        "description": "Constant declaration"
    },
    "Cast int": {
        "prefix": "toi",
        "body": [
            "i(${0:value})"
        ],
        "description": "Cast to int: i(x)"
    },
    "Cast float": {
        "prefix": "tof",
        "body": [
            "f(${0:value})"
        ],
        "description": "Cast to float: f(x)"
    },
    "Cast string": {
        "prefix": "tos",
        "body": [
            "s(${0:value})"
        ],
        "description": "Cast to string: s(x)"
    },
    "--- Functions ---": {
        "prefix": "xfunc",
        "body": [
            "--- Functions ---"
        ],
        "description": "Section marker"
    },
    "Function (void)": {
        "prefix": "func",
        "body": [
            "func ${1:name}(${2:s: param}) {",
            "    ${0}",
            "};"
        ],
        "description": "Function without return value"
    },
    "Function (with return)": {
        "prefix": "funcr",
        "body": [
            "func ${1:name}(${2:s: param} -> ${3:i}) {",
            "    ${0}",
            "    return ${4:value};",
            "};"
        ],
        "description": "Function with return value"
    },
    "Function (no params, return)": {
        "prefix": "funcnp",
        "body": [
            "func ${1:name}(-> ${2:i}) {",
            "    return ${0};",
            "};"
        ],
        "description": "Function without params, with return"
    },
    "Function (no params, void)": {
        "prefix": "funcv",
        "body": [
            "func ${1:name}() {",
            "    ${0}",
            "};"
        ],
        "description": "Void function without params"
    },
    "--- Fibers ---": {
        "prefix": "xfiber",
        "body": [
            "--- Fibers ---"
        ],
        "description": "Section marker"
    },
    "Fiber (typed)": {
        "prefix": "fiber",
        "body": [
            "fiber ${1:name}(${2:s: param} -> ${3:json}) {",
            "    ${0}",
            "    yield ${4:value};",
            "};"
        ],
        "description": "Typed fiber — yield returns value"
    },
    "Fiber (void)": {
        "prefix": "fiberv",
        "body": [
            "fiber ${1:name}(${2:s: param}) {",
            "    ${0}",
            "    yield;",
            "};"
        ],
        "description": "Void fiber — yield without value"
    },
    "Fiber HTTP handler": {
        "prefix": "fiberh",
        "body": [
            "fiber ${1:handle_name}(json: req -> json) {",
            "    ${0}",
            "    yield net.respond(200, <<< {\"status\": \"ok\"} >>>);",
            "};"
        ],
        "description": "HTTP handler fiber — signature required by serve:"
    },
    "Fiber instance (typed)": {
        "prefix": "fiberi",
        "body": [
            "fiber:${1:b}: ${2:f} = ${3:fiber_name}(${4:args});",
            "${1}: ${5:result} = ${2}.next();"
        ],
        "description": "Create typed fiber and get first yielded value"
    },
    "Fiber instance (void)": {
        "prefix": "fiberiv",
        "body": [
            "fiber: ${1:f} = ${2:fiber_name}(${3:args});",
            "${1}.run();"
        ],
        "description": "Create void fiber and run one step"
    },
    "Fiber pipeline (chain)": {
        "prefix": "fiberpipe",
        "body": [
            "fiber ${1:pipeline}(${2:s: param} -> ${3:b}) {",
            "    fiber:${4:b}: ${5:step1} = ${6:check_one}(${2});",
            "    yield ${5}.next();",
            "",
            "    fiber:${4}: ${7:step2} = ${8:check_two}(${2});",
            "    yield ${7}.next();",
            "};"
        ],
        "description": "Fiber calling other fibers (pipeline pattern)"
    },
    "Fiber loop (.isDone)": {
        "prefix": "fiberloop",
        "body": [
            "while (${1:f}.isDone() == false) do;",
            "    ${2:type}: ${3:val} = ${1}.next();",
            "    ${0}",
            "end;"
        ],
        "description": "Consume fiber until done"
    },
    "For over fiber": {
        "prefix": "forfib",
        "body": [
            "for ${1:val} in ${2:f} do;",
            "    ${0}",
            "end;"
        ],
        "description": "for loop over fiber (auto-calls .next, .close on break)"
    },
    "yield": {
        "prefix": "yield",
        "body": [
            "yield ${0};"
        ],
        "description": "yield value in typed fiber"
    },
    "yield void": {
        "prefix": "yieldv",
        "body": [
            "yield;"
        ],
        "description": "yield in void fiber"
    },
    "--- Control Flow ---": {
        "prefix": "xcflow",
        "body": [
            "--- Control Flow ---"
        ],
        "description": "Section marker"
    },
    "If": {
        "prefix": "if",
        "body": [
            "if (${1:condition}) then;",
            "    ${0}",
            "end;"
        ],
        "description": "If statement"
    },
    "If-Else": {
        "prefix": "ifelse",
        "body": [
            "if (${1:condition}) then;",
            "    ${2}",
            "else;",
            "    ${0}",
            "end;"
        ],
        "description": "If-else statement"
    },
    "If-Elif-Else": {
        "prefix": "ifelif",
        "body": [
            "if (${1:condition}) then;",
            "    ${2}",
            "elif (${3:condition2}) then;",
            "    ${4}",
            "else;",
            "    ${0}",
            "end;"
        ],
        "description": "If-elif-else (also: elf, els aliases)"
    },
    "If inline guard": {
        "prefix": "ifg",
        "body": [
            "if (${1:!ok}) then; ${0}; end;"
        ],
        "description": "Single-line inline guard"
    },
    "If guard — yield error + return": {
        "prefix": "ifguard",
        "body": [
            "if (!${1:ok}) then;",
            "    yield net.respond(${2:401}, <<< {\"error\": \"${3:Unauthorized}\"} >>>);",
            "    return;",
            "end;"
        ],
        "description": "Auth/validation guard with early return"
    },
    "--- Loops ---": {
        "prefix": "xloops",
        "body": [
            "--- Loops ---"
        ],
        "description": "Section marker"
    },
    "While": {
        "prefix": "while",
        "body": [
            "while (${1:condition}) do;",
            "    ${0}",
            "end;"
        ],
        "description": "While loop"
    },
    "For (range)": {
        "prefix": "forr",
        "body": [
            "for ${1:i} in ${2:0} to ${3:n} do;",
            "    ${0}",
            "end;"
        ],
        "description": "For loop — inclusive range [start, end]"
    },
    "For (range with @step)": {
        "prefix": "forrs",
        "body": [
            "for ${1:i} in ${2:0} to ${3:n} @step ${4:2} do;",
            "    ${0}",
            "end;"
        ],
        "description": "For loop with step"
    },
    "For (collection)": {
        "prefix": "forin",
        "body": [
            "for ${1:item} in ${2:collection} do;",
            "    ${0}",
            "end;"
        ],
        "description": "For loop over array, set or fiber"
    },
    "For (index over array)": {
        "prefix": "foridx",
        "body": [
            "for ${1:i} in 0 to (${2:arr}.size() - 1) do;",
            "    ${3:type}: ${4:val} = ${2}.get(${1});",
            "    ${0}",
            "end;"
        ],
        "description": "For loop with explicit index"
    },
    "--- HTTP Server ---": {
        "prefix": "xhttp",
        "body": [
            "--- HTTP Server ---"
        ],
        "description": "Section marker"
    },
    "serve block": {
        "prefix": "serve",
        "body": [
            "serve: ${1:api_name} {",
            "    port    = ${2:8080},",
            "    host    = \"${3:0.0.0.0}\",",
            "    workers = ${4:4},",
            "    routes  = [",
            "        \"GET    ${5:/api/items}\"  :: ${6:handle_get},",
            "        \"POST   ${5:/api/items}\"  :: ${7:handle_post},",
            "        \"OPTIONS *\"               :: handle_options,",
            "        \"*\"                       :: handle_404",
            "    ]",
            "};"
        ],
        "description": "HTTP serve block — terminal expression"
    },
    "net.respond": {
        "prefix": "respond",
        "body": [
            "yield net.respond(${1:200}, ${0:resp});"
        ],
        "description": "yield net.respond(status, body)"
    },
    "net.respond with headers": {
        "prefix": "respondh",
        "body": [
            "yield net.respond(${1:200}, ${2:resp}, [",
            "    \"${3:Header-Name}\" :: \"${4:value}\"",
            "]);"
        ],
        "description": "yield net.respond with custom headers"
    },
    "net.respond inline": {
        "prefix": "respondi",
        "body": [
            "yield net.respond(${1:200}, <<< {\"${2:status}\": \"${3:ok}\"} >>>);"
        ],
        "description": "yield net.respond with inline JSON literal"
    },
    "handle_options (CORS preflight)": {
        "prefix": "handleopts",
        "body": [
            "fiber handle_options(json: req -> json) {",
            "    yield net.respond(204, <<< {} >>>, [",
            "        \"Access-Control-Allow-Methods\" :: \"GET, POST, DELETE, PATCH, OPTIONS\",",
            "        \"Access-Control-Allow-Headers\" :: \"Content-Type, Authorization, X-CSRF-TOKEN\"",
            "    ]);",
            "};"
        ],
        "description": "CORS OPTIONS preflight handler"
    },
    "handle_404": {
        "prefix": "handle404",
        "body": [
            "fiber handle_404(json: req -> json) {",
            "    yield net.respond(404, <<< {\"error\": \"Not found\"} >>>);",
            "};"
        ],
        "description": "404 fallback handler"
    },
    "Auth token extract (Bearer)": {
        "prefix": "authextract",
        "body": [
            "json: headers;",
            "req.bind(\"headers\", headers);",
            "s: auth;",
            "headers.bind(\"authorization\", auth);",
            "s: ${1:sess_token} = auth.slice(7, auth.length);"
        ],
        "description": "Extract Bearer token from Authorization header"
    },
    "net.get": {
        "prefix": "netget",
        "body": [
            "json: ${1:resp} = net.get(${2:url});"
        ],
        "description": "HTTP GET request"
    },
    "net.post": {
        "prefix": "netpost",
        "body": [
            "json: ${1:resp} = net.post(${2:url}, ${3:body});"
        ],
        "description": "HTTP POST request"
    },
    "net.request (low-level)": {
        "prefix": "netreq",
        "body": [
            "net.request {",
            "    method  = \"${1:POST}\",",
            "    url     = \"${2:https://api.example.com/data}\",",
            "    headers = [\"Authorization\" :: \"Bearer ${3:token}\"],",
            "    body    = ${4:my_json},",
            "    timeout = ${5:5000}",
            "} as ${6:resp};"
        ],
        "description": "Low-level HTTP request builder"
    },
    "--- Tables ---": {
        "prefix": "xtable",
        "body": [
            "--- Tables ---"
        ],
        "description": "Section marker"
    },
    "Table definition (empty)": {
        "prefix": "table",
        "body": [
            "table: ${1:name} {",
            "    columns = [",
            "        id     :: i @auto,",
            "        ${2:field} :: ${3:s}",
            "    ]",
            "    rows = [EMPTY]",
            "};"
        ],
        "description": "Empty table with @auto id"
    },
    "Table definition (with rows)": {
        "prefix": "tabledata",
        "body": [
            "table: ${1:name} {",
            "    columns = [",
            "        id     :: i @auto,",
            "        ${2:name}  :: s,",
            "        ${3:price} :: f",
            "    ]",
            "    rows = [",
            "        (\"${4:Item}\", ${5:9.99})",
            "    ]",
            "};"
        ],
        "description": "Table with initial rows"
    },
    "Table .where()": {
        "prefix": "where",
        "body": [
            "table: ${1:result} = ${2:tbl}.where(${3:column} == ${4:value});"
        ],
        "description": "Filter table rows"
    },
    "Table .where() chained": {
        "prefix": "wherechain",
        "body": [
            "table: ${1:result} = ${2:tbl}",
            "    .where(${3:col1} == ${4:val1})",
            "    .where(${5:col2} == ${6:val2});"
        ],
        "description": "Chained .where() filters"
    },
    "Table .where() with lambda": {
        "prefix": "wherelambda",
        "body": [
            "table: ${1:result} = ${2:tbl}.where(row -> row.${3:field} > ${4:value});"
        ],
        "description": "Filter with lambda row -> expr"
    },
    "Table .join()": {
        "prefix": "join",
        "body": [
            "table: ${1:result} = ${2:tableA}.join(${3:tableB}, \"${4:id}\", \"${5:ref_id}\");"
        ],
        "description": "Inner join two tables on key columns"
    },
    "Table .insert()": {
        "prefix": "insert",
        "body": [
            "${1:tbl}.insert(${0:values});"
        ],
        "description": "Insert row (skip @auto columns)"
    },
    "Table .update()": {
        "prefix": "update",
        "body": [
            "${1:tbl}.update(${2:idx}, [${0:values}]);"
        ],
        "description": "Update row by index"
    },
    "Table .delete()": {
        "prefix": "delete",
        "body": [
            "${1:tbl}.delete(${2:idx});"
        ],
        "description": "Delete row by index"
    },
    "Table get field": {
        "prefix": "tget",
        "body": [
            "${1:type}: ${2:val} = ${3:tbl}.get(${4:idx}).${5:field};"
        ],
        "description": "Get field value from table row"
    },
    "Table find index by field": {
        "prefix": "tfind",
        "body": [
            "i: ${1:found_idx} = -1;",
            "i: ${2:total} = ${3:tbl}.count();",
            "i: ${4:fi} = 0;",
            "while (${4:fi} < ${2:total}) do;",
            "    if (${3:tbl}.get(${4:fi}).${5:id} == ${6:target}) then;",
            "        ${1:found_idx} = ${4:fi};",
            "        break;",
            "    end;",
            "    ${4:fi} = ${4:fi} + 1;",
            "end;",
            "if (${1:found_idx} == -1) then; ${0}; end;"
        ],
        "description": "Find row index by field value (returns -1 if not found)"
    },
    "--- JSON ---": {
        "prefix": "xjson",
        "body": [
            "--- JSON ---"
        ],
        "description": "Section marker"
    },
    "JSON literal": {
        "prefix": "jsonraw",
        "body": [
            "json: ${1:name} <<< {${0}} >>>;"
        ],
        "description": "JSON raw block literal"
    },
    "JSON parse": {
        "prefix": "jsonp",
        "body": [
            "json: ${1:data} = json.parse(${2:raw_string});"
        ],
        "description": "Parse JSON string (panics on invalid JSON — R305)"
    },
    "JSON .set()": {
        "prefix": "jset",
        "body": [
            "${1:obj}.set(\"${2:key}\", ${3:value});"
        ],
        "description": "Set JSON field value"
    },
    "JSON .bind()": {
        "prefix": "jbind",
        "body": [
            "${1:type}: ${2:var};",
            "${3:obj}.bind(\"${4:key}\", ${2:var});"
        ],
        "description": "Extract JSON field into typed variable"
    },
    "JSON .exists()": {
        "prefix": "jexists",
        "body": [
            "if (${1:obj}.exists(\"${2:key}\")) then;",
            "    ${0}",
            "end;"
        ],
        "description": "Check if JSON key exists before binding"
    },
    "JSON array push via bracket notation": {
        "prefix": "jpush",
        "body": [
            "s: ${1:path} = \"${2:items}[\" + ${3:idx} + \"]\";",
            "${4:obj}.set(${1:path}, ${5:item});"
        ],
        "description": "Append item to JSON array via bracket notation"
    },
    "JSON .inject() to table": {
        "prefix": "jinject",
        "body": [
            "map: ${1:mapping} {",
            "    schema = [s <-> s]",
            "    data   = [\"${2:col}\" :: \"${3:json_key}\"]",
            "};",
            "${4:json_obj}.inject(\"${5:array_key}\", ${1:mapping}, ${6:tbl});"
        ],
        "description": "Bulk import JSON array into XCX table"
    },
    "JSON .to_str()": {
        "prefix": "jstr",
        "body": [
            "s: ${1:str} = ${2:obj}.to_str();"
        ],
        "description": "Serialize JSON to string"
    },
    "JSON response builder": {
        "prefix": "jresp",
        "body": [
            "json: ${1:resp} <<< {\"status\": \"ok\", \"${2:key}\": ${3:0}} >>>;",
            "${1:resp}.set(\"${2:key}\", ${4:value});",
            "yield net.respond(${5:200}, ${1:resp});"
        ],
        "description": "Build mutable JSON response and yield"
    },
    "--- Arrays ---": {
        "prefix": "xarray",
        "body": [
            "--- Arrays ---"
        ],
        "description": "Section marker"
    },
    "Array declaration": {
        "prefix": "array",
        "body": [
            "array:${1|i,f,s,b|}: ${2:name} {${0}};"
        ],
        "description": "Array declaration"
    },
    "Array empty": {
        "prefix": "arraye",
        "body": [
            "array:${1|i,f,s,b|}: ${2:name} {};"
        ],
        "description": "Empty array"
    },
    "--- Sets ---": {
        "prefix": "xset",
        "body": [
            "--- Sets ---"
        ],
        "description": "Section marker"
    },
    "Set (range)": {
        "prefix": "setr",
        "body": [
            "set:${1|N,Z,Q,C|}: ${2:name} {${3:1},,${4:10}};"
        ],
        "description": "Set with inclusive range"
    },
    "Set (range with @step)": {
        "prefix": "setrs",
        "body": [
            "set:${1|N,Z,Q|}: ${2:name} {${3:0},,${4:100} @step ${5:2}};"
        ],
        "description": "Set with range and step"
    },
    "Set (explicit)": {
        "prefix": "sete",
        "body": [
            "set:${1|N,Z,Q,S,B,C|}: ${2:name} {${0}};"
        ],
        "description": "Set with explicit elements"
    },
    "random.choice": {
        "prefix": "randchoice",
        "body": [
            "${1:i}: ${2:picked} = random.choice from ${3:my_set};"
        ],
        "description": "Pick random element from set"
    },
    "--- Maps ---": {
        "prefix": "xmap",
        "body": [
            "--- Maps ---"
        ],
        "description": "Section marker"
    },
    "Map (empty)": {
        "prefix": "map",
        "body": [
            "map: ${1:name} {",
            "    schema = [${2:s} <-> ${3:i}]",
            "    data   = [EMPTY]",
            "};"
        ],
        "description": "Empty map"
    },
    "Map (with data)": {
        "prefix": "mapd",
        "body": [
            "map: ${1:name} {",
            "    schema = [${2:s} <-> ${3:i}]",
            "    data   = [",
            "        \"${4:key}\" :: ${5:value}",
            "    ]",
            "};"
        ],
        "description": "Map with initial data"
    },
    "Map safe get": {
        "prefix": "mapget",
        "body": [
            "if (${1:m}.contains(${2:key})) then;",
            "    ${3:type}: ${4:val} = ${1:m}.get(${2:key});",
            "    ${0}",
            "end;"
        ],
        "description": "Safe map access with .contains() guard"
    },
    "--- Error Handling ---": {
        "prefix": "xerr",
        "body": [
            "--- Error Handling ---"
        ],
        "description": "Section marker"
    },
    "halt.alert": {
        "prefix": "alert",
        "body": [
            "halt.alert >! \"${1:message}\";"
        ],
        "description": "Warning — program continues (log/debug)"
    },
    "halt.error": {
        "prefix": "herror",
        "body": [
            "halt.error >! \"${1:message}\";"
        ],
        "description": "Error — stops current frame, caller continues"
    },
    "halt.fatal": {
        "prefix": "fatal",
        "body": [
            "halt.fatal >! \"${1:message}\";"
        ],
        "description": "Fatal — immediately terminates entire VM"
    },
    "Safe divide": {
        "prefix": "safediv",
        "body": [
            "if (${1:divisor} == 0) then;",
            "    halt.error >! \"Division by zero in ${2:context}\";",
            "    return ${3:-1};",
            "end;",
            "${4:type}: ${5:result} = ${6:num} / ${1:divisor};"
        ],
        "description": "Guard against division by zero"
    },
    "--- Store (File I/O) ---": {
        "prefix": "xstore",
        "body": [
            "--- Store (File I/O) ---"
        ],
        "description": "Section marker"
    },
    "store.write": {
        "prefix": "storewrite",
        "body": [
            "store.write(\"${1:file.txt}\", ${2:content});"
        ],
        "description": "Write string to file (creates if missing)"
    },
    "store.read (safe)": {
        "prefix": "storeread",
        "body": [
            "if (store.exists(\"${1:file.txt}\")) then;",
            "    s: ${2:content} = store.read(\"${1:file.txt}\");",
            "    ${0}",
            "end;"
        ],
        "description": "Read file with exists() guard"
    },
    "store.append": {
        "prefix": "storeappend",
        "body": [
            "store.append(\"${1:file.txt}\", ${2:content});"
        ],
        "description": "Append to file"
    },
    "--- Crypto ---": {
        "prefix": "xcrypto",
        "body": [
            "--- Crypto ---"
        ],
        "description": "Section marker"
    },
    "crypto.hash (argon2)": {
        "prefix": "cryptohash",
        "body": [
            "s: ${1:hash} = crypto.hash(${2:password}, \"argon2\");"
        ],
        "description": "Hash with argon2 (recommended)"
    },
    "crypto.verify": {
        "prefix": "cryptoverify",
        "body": [
            "b: ${1:ok} = crypto.verify(${2:input}, ${3:hash}, \"argon2\");"
        ],
        "description": "Verify argon2 hash"
    },
    "crypto.token": {
        "prefix": "cryptotoken",
        "body": [
            "s: ${1:token} = crypto.token(${2:32});"
        ],
        "description": "Generate random hex token (N bytes)"
    },
    "--- Date ---": {
        "prefix": "xdate",
        "body": [
            "--- Date ---"
        ],
        "description": "Section marker"
    },
    "date.now()": {
        "prefix": "datenow",
        "body": [
            "date: ${1:now} = date.now();"
        ],
        "description": "Get current date and time"
    },
    "date literal": {
        "prefix": "datelit",
        "body": [
            "date: ${1:d} = date(\"${2:2026-01-01}\");"
        ],
        "description": "Date from ISO string"
    },
    "date format": {
        "prefix": "datefmt",
        "body": [
            "s: ${1:str} = ${2:now}.format(\"${3:DD/MM/YYYY HH:mm}\");"
        ],
        "description": "Format date to string"
    },
    "Rate limit key (date-based)": {
        "prefix": "ratelimitkey",
        "body": [
            "date: ${1:now} = date.now();",
            "s: ${2:key} = ${3:ip} + \":\" + ${1:now}.hour + \":\" + ${1:now}.minute;"
        ],
        "description": "Build per-minute rate limit key from IP + timestamp"
    },
    "--- Modules ---": {
        "prefix": "xmod",
        "body": [
            "--- Modules ---"
        ],
        "description": "Section marker"
    },
    "include": {
        "prefix": "inc",
        "body": [
            "include \"${1:module.xcx}\";"
        ],
        "description": "Include module into current namespace"
    },
    "include as": {
        "prefix": "incas",
        "body": [
            "include \"${1:module.xcx}\" as ${2:alias};"
        ],
        "description": "Include module with alias prefix"
    },
    "--- I/O ---": {
        "prefix": "xio",
        "body": [
            "--- I/O ---"
        ],
        "description": "Section marker"
    },
    "print": {
        "prefix": "print",
        "body": [
            ">! ${0};"
        ],
        "description": "Print output (>!)"
    },
    "input": {
        "prefix": "input",
        "body": [
            ">! \"${1:Prompt}:\";",
            "${2|i,f,s,b|}: ${3:var};",
            ">? ${3:var};"
        ],
        "description": "Print prompt and read input (>?)"
    },
    "@wait": {
        "prefix": "wait",
        "body": [
            "@wait ${1:500};"
        ],
        "description": "Synchronous delay in milliseconds"
    },
    ".terminal !clear": {
        "prefix": "termclear",
        "body": [
            ".terminal !clear;"
        ],
        "description": "Clear terminal screen"
    },
    ".terminal !exit": {
        "prefix": "termexit",
        "body": [
            ".terminal !exit;"
        ],
        "description": "Exit runtime immediately"
    }
