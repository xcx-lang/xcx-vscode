{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "PAX Configuration",
    "scopeName": "source.pax",
    "patterns": [
        { "include": "#comments" },
        { "include": "#delimiters" },
        { "include": "#strings" },
        { "include": "#arrays" },
        { "include": "#operators" },
        { "include": "#keywords" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.pax",
                    "begin": "^\\s*---\\s*$",
                    "end": "^\\s*\\*---\\s*$",
                    "patterns": []
                },
                {
                    "name": "comment.line.pax",
                    "match": "---.*$"
                }
            ]
        },
        "delimiters": {
            "patterns": [
                {
                    "name": "keyword.control.pax",
                    "match": "/"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.pax",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.pax",
                    "match": "\\\\."
                }
            ]
        },
        "arrays": {
            "name": "punctuation.definition.array.pax",
            "match": "[\\[\\]]"
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.pax",
                    "match": "::"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "variable.other.pax",
                    "match": "\\b(name|deps)\\b"
                }
            ]
        }
    }
}
